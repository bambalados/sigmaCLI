# Sigma.Money CLI Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it's in .gitignore.

# ── Private Key ──
# Required for write operations (trade, stake, vote, etc.)
# Use a DEDICATED wallet with limited funds — never your main wallet.
# Preferred: use `sigma config set-key` to store in macOS Keychain instead.
SIGMA_PRIVATE_KEY=

# ── RPC Configuration (pick one) ──

# Option 1: NodeReal (Recommended)
# Free tier with generous rate limits for BSC.
# Sign up at https://nodereal.io/ (free), create a BSC mainnet API key.
# Or store via: sigma config set-rpc-key
# SIGMA_NODEREAL_KEY=your-api-key-here

# Option 2: Custom RPC URL
# Any BSC-compatible RPC endpoint.
# SIGMA_RPC_URL=https://your-custom-rpc/

# Default (no config needed): Public BSC RPC (https://bsc-dataseed.binance.org/)
# Works for basic usage but may be rate-limited under heavy use.
